        slot_found = False
        selected_date_text = ""
        slot_time_value = ""
    
        for date in all_dates:
            selected_date_text = date.text.strip()  # e.g. "Wed, Feb 4"
            date.click()
            time.sleep(2)
    
            # Case 1: No slots → move to next day
